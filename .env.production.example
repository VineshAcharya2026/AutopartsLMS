# Production environment template (API on Render / Cloud Run)
# Copy values into Render dashboard env vars or Cloud Run secrets.

DATABASE_URL=postgresql://user:pass@host:5432/centercrm
JWT_SECRET=replace-with-long-random-string
FERNET_KEY=replace-with-32-byte-base64-fernet-key==
COOKIE_SECURE=true
CORS_ORIGINS=https://autoparts-lms.web.app,https://autoparts-lms.firebaseapp.com
REDIS_URL=redis://127.0.0.1:6379/0

# Set when rebuilding Firebase static frontend:
# NEXT_PUBLIC_API_URL=https://YOUR-API-URL/api/v1
# NEXT_PUBLIC_WS_URL=wss://YOUR-API-URL/ws/notifications

# App Hosting only (Blaze plan):
# BACKEND_URL=https://YOUR-API-URL
