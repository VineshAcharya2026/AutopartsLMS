{
  "apphosting": [
    {
      "backendId": "web",
      "rootDir": "apps/web",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"]
    }
  ],
  "hosting": {
    "site": "autoparts-lms",
    "public": "apps/web/out",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "headers": [
      {
        "source": "**/*.@(js|css|svg|png|jpg|jpeg|gif|webp|ico|woff|woff2)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ]
  }
}
