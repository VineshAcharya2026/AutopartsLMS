# Database
DATABASE_URL=postgresql://centercrm:centercrm@localhost:5432/centercrm

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# Encryption for integration secrets
FERNET_KEY=change-me-32-byte-base64-fernet-key==

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,https://autoparts-lms.web.app,https://autoparts-lms.firebaseapp.com

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/notifications

# Google OAuth (optional — enables Sign in with Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/oauth/google/callback
FRONTEND_OAUTH_CALLBACK_URL=http://localhost:3000/auth/callback

# Twilio (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Resend (optional)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@centercrm.com

# Storage
STORAGE_PATH=./storage
UPLOAD_MAX_SIZE_MB=10
